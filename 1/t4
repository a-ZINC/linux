<!-- S3 -->
<div class="section" id="s3">
  <div class="section-header">
    <div class="section-icon">⚙️</div>
    <div><div class="section-title">Commands & Syntax</div><div class="section-num">Section 03 — Full apt and dpkg command reference</div></div>
  </div>

  <h3>apt — daily workflow</h3>
  <pre><code><span class="cm"># ── Update & Upgrade ──────────────────────────────────────────────</span>
<span class="cn">apt update</span>                        <span class="cm"># refresh package index from all repos</span>
                                   <span class="cm"># (does NOT install anything — just fetches metadata)</span>
<span class="cn">apt upgrade</span>                       <span class="cm"># upgrade all packages to newest version</span>
<span class="cn">apt full-upgrade</span>                  <span class="cm"># upgrade + remove packages if needed to resolve deps</span>
                                   <span class="cm"># (safer name for old apt-get dist-upgrade)</span>
<span class="cn">apt upgrade</span> <span class="fl">--dry-run</span>             <span class="cm"># simulate: show what WOULD be upgraded</span>

<span class="cm"># ── Install ───────────────────────────────────────────────────────</span>
<span class="cn">apt install</span> <span class="st">nginx</span>                <span class="cm"># install nginx</span>
<span class="cn">apt install</span> <span class="st">nginx=1.18.0-0ubuntu1</span><span class="cm"> # install specific version</span>
<span class="cn">apt install</span> <span class="st">nginx curl git</span>       <span class="cm"># install multiple packages</span>
<span class="cn">apt install</span> <span class="fl">--no-install-recommends</span> <span class="st">nginx</span>  <span class="cm"># skip recommended (for minimal installs)</span>
<span class="cn">apt install</span> <span class="fl">-f</span>                    <span class="cm"># fix broken dependencies</span>
<span class="cn">apt install</span> <span class="fl">--reinstall</span> <span class="st">nginx</span>    <span class="cm"># reinstall package (corrupted files)</span>

<span class="cm"># ── Remove ────────────────────────────────────────────────────────</span>
<span class="cn">apt remove</span> <span class="st">nginx</span>                  <span class="cm"># remove package, KEEP config files</span>
<span class="cn">apt purge</span> <span class="st">nginx</span>                   <span class="cm"># remove package AND config files</span>
<span class="cn">apt autoremove</span>                    <span class="cm"># remove packages no longer needed as deps</span>
<span class="cn">apt autoremove</span> <span class="fl">--purge</span>            <span class="cm"># autoremove + purge their configs too</span>

<span class="cm"># ── Search & Info ─────────────────────────────────────────────────</span>
<span class="cn">apt search</span> <span class="st">nginx</span>                  <span class="cm"># search package names and descriptions</span>
<span class="cn">apt show</span> <span class="st">nginx</span>                    <span class="cm"># show full package details</span>
<span class="cn">apt list</span> <span class="fl">--installed</span>              <span class="cm"># list all installed packages</span>
<span class="cn">apt list</span> <span class="fl">--upgradable</span>             <span class="cm"># list packages with available upgrades</span>
<span class="cn">apt-cache</span> <span class="st">depends nginx</span>          <span class="cm"># show what nginx depends on</span>
<span class="cn">apt-cache</span> <span class="st">rdepends nginx</span>         <span class="cm"># show what depends ON nginx (reverse)</span>
<span class="cn">apt-cache</span> <span class="st">policy nginx</span>           <span class="cm"># show installed vs candidate version + repo priority</span>

<span class="cm"># ── Clean ─────────────────────────────────────────────────────────</span>
<span class="cn">apt clean</span>                         <span class="cm"># delete ALL cached .deb files from /var/cache/apt/archives</span>
<span class="cn">apt autoclean</span>                     <span class="cm"># delete only outdated cached .debs</span></code></pre>

  <h3>Package pinning — hold versions</h3>
  <pre><code><span class="cm"># Hold a package at its current version (won't be upgraded)</span>
<span class="cn">apt-mark hold</span> <span class="st">nginx</span>               <span class="cm"># hold nginx at current version</span>
<span class="cn">apt-mark unhold</span> <span class="st">nginx</span>             <span class="cm"># release the hold</span>
<span class="cn">apt-mark showhold</span>                  <span class="cm"># list all held packages</span>

<span class="cm"># dpkg method (equivalent):</span>
<span class="cn">echo</span> <span class="st">"nginx hold"</span> | <span class="cn">dpkg --set-selections</span>
<span class="cn">dpkg --get-selections</span> | <span class="cn">grep hold</span> <span class="cm"># verify</span>

<span class="cm"># Advanced: pin via preferences file</span>
<span class="cm"># /etc/apt/preferences.d/nginx-pin</span>
<span class="kw">Package:</span> nginx
<span class="kw">Pin:</span> version 1.18.0-0ubuntu1
<span class="kw">Pin-Priority:</span> 1001         <span class="cm"># >1000 = hold even if installed version is newer</span></code></pre>

  <h3>dpkg — low-level operations</h3>
  <pre><code><span class="cm"># Install/query .deb files directly</span>
<span class="cn">dpkg</span> <span class="fl">-i</span> <span class="st">package.deb</span>               <span class="cm"># install a local .deb file</span>
<span class="cn">dpkg</span> <span class="fl">-r</span> <span class="st">nginx</span>                      <span class="cm"># remove package (keep configs)</span>
<span class="cn">dpkg</span> <span class="fl">-P</span> <span class="st">nginx</span>                      <span class="cm"># purge package (remove configs too)</span>

<span class="cm"># Query the installed package database</span>
<span class="cn">dpkg</span> <span class="fl">-l</span>                            <span class="cm"># list all packages + status</span>
<span class="cn">dpkg</span> <span class="fl">-l</span> <span class="st">nginx</span>                      <span class="cm"># check install status of nginx</span>
<span class="cn">dpkg</span> <span class="fl">-L</span> <span class="st">nginx</span>                      <span class="cm"># list all files installed BY nginx</span>
<span class="cn">dpkg</span> <span class="fl">-S</span> <span class="st">/usr/sbin/nginx</span>           <span class="cm"># which package owns this file?</span>
<span class="cn">dpkg</span> <span class="fl">--status</span> <span class="st">nginx</span>               <span class="cm"># full package metadata</span>
<span class="cn">dpkg</span> <span class="fl">--print-architecture</span>         <span class="cm"># what arch is this system?</span>

<span class="cm"># Reading dpkg -l status columns:</span>
<span class="cm"># ii  nginx  1.18.0  amd64  high performance web server</span>
<span class="cm"># ↑↑</span>
<span class="cm"># First char: desired state (i=install, h=hold, r=remove, p=purge)</span>
<span class="cm"># Second char: current state (i=installed, c=config-files, n=not-installed)</span>
<span class="cm"># Third char: error flag (space=ok, R=reinst-required, H=half-installed)</span>

<span class="cm"># Reconfigure an installed package:</span>
<span class="cn">dpkg-reconfigure</span> <span class="st">tzdata</span>           <span class="cm"># re-run the post-install config wizard</span>
<span class="cn">dpkg-reconfigure</span> <span class="st">locales</span>         <span class="cm"># useful after a locale issue</span></code></pre>

  <h3>Adding third-party repositories (modern method)</h3>
  <pre><code><span class="cm"># Modern pattern (Ubuntu 22.04+) — using signed-by and /etc/apt/keyrings/</span>
<span class="cm"># Example: adding Docker's official repository</span>

<span class="cm"># Step 1: Install prerequisites</span>
<span class="cn">apt install</span> <span class="fl">-y</span> ca-certificates curl

<span class="cm"># Step 2: Download and store GPG key</span>
<span class="cn">install</span> <span class="fl">-m 0755 -d</span> /etc/apt/keyrings
<span class="cn">curl</span> <span class="fl">-fsSL</span> https://download.docker.com/linux/ubuntu/gpg \
  | <span class="cn">gpg --dearmor -o</span> /etc/apt/keyrings/docker.gpg
<span class="cn">chmod</span> a+r /etc/apt/keyrings/docker.gpg

<span class="cm"># Step 3: Add repository with signed-by reference</span>
echo <span class="st">"deb [arch=amd64 signed-by=/etc/apt/keyrings/docker.gpg] \
  https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable"</span> \
  | <span class="cn">tee</span> /etc/apt/sources.list.d/docker.list > /dev/null

<span class="cm"># Step 4: Update and install</span>
<span class="cn">apt update</span> && <span class="cn">apt install</span> docker-ce

<span class="cm"># Old (insecure) pattern — avoid on new systems:</span>
<span class="cm"># apt-key add keyfile.gpg  ← deprecated, adds to shared keyring</span></code></pre>

  <h3>snap — universal package format</h3>
  <pre><code><span class="cn">snap find</span> <span class="st">chromium</span>               <span class="cm"># search snap store</span>
<span class="cn">snap install</span> <span class="st">chromium</span>            <span class="cm"># install snap package</span>
<span class="cn">snap list</span>                         <span class="cm"># list installed snaps</span>
<span class="cn">snap info</span> <span class="st">chromium</span>               <span class="cm"># show snap details and available channels</span>
<span class="cn">snap refresh</span>                      <span class="cm"># update all snaps</span>
<span class="cn">snap refresh</span> <span class="st">chromium</span>            <span class="cm"># update specific snap</span>
<span class="cn">snap remove</span> <span class="st">chromium</span>             <span class="cm"># remove snap</span>
<span class="cn">snap revert</span> <span class="st">chromium</span>             <span class="cm"># roll back to previous version</span>
<span class="cn">snap connections</span> <span class="st">chromium</span>        <span class="cm"># show what interfaces (permissions) snap uses</span></code></pre>
</div>

