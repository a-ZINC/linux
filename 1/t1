<button class="mob-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>

<script>
  // Scroll progress
  window.addEventListener('scroll', updateNav);

  function updateNav() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? Math.round((scrollTop / docHeight) * 100) : 0;
    document.getElementById('progress').style.width = pct + '%';
    document.getElementById('prog-label').textContent = pct + '% read';

    // Active nav highlight based on scroll position
    const navItems = document.querySelectorAll('.nav-item');
    const targets = ['overview','s1','s2','s3','s4','s5','s6','s7','s8','s9','s10','s11','s12','s13','s14','s15','s16','s17','s18','s19','s20'];
    let current = 'overview';
    for (const id of targets) {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top <= 120) current = id;
    }
    navItems.forEach(item => {
      item.classList.toggle('active', item.getAttribute('href') === '#' + current);
    });
  }

  // Click nav item — set active immediately, then scroll
  document.querySelectorAll('.nav-item').forEach(item => {
    item.addEventListener('click', function(e) {
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
      this.classList.add('active');
      // Also scroll the sidebar to keep active item visible
      const sidebar = document.querySelector('.sidebar');
      const itemTop = this.offsetTop;
      const sidebarHeight = sidebar.clientHeight;
      if (itemTop > sidebar.scrollTop + sidebarHeight - 80 || itemTop < sidebar.scrollTop + 60) {
        sidebar.scrollTop = itemTop - sidebarHeight / 2;
      }
    });
  });

  // Run once on load
  updateNav();
</script>
