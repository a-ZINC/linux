  <h3>sources.list format</h3>
  <pre><code><span class="cm"># /etc/apt/sources.list — one line per repository</span>
<span class="cm"># Format: deb [options] uri suite components...</span>

deb http://archive.ubuntu.com/ubuntu jammy main restricted universe multiverse
<span class="cm"># deb         = binary packages (deb-src = source packages)</span>
<span class="cm"># jammy       = Ubuntu 22.04 codename</span>
<span class="cm"># main etc    = repository components</span>

deb http://archive.ubuntu.com/ubuntu jammy-security main restricted
deb http://archive.ubuntu.com/ubuntu jammy-updates main restricted universe

<span class="cm"># Third-party with signed-by (modern format):</span>
deb [arch=amd64 signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu jammy stable</code></pre>
