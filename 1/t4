  document.getElementById('progress').style.width=pct+'%';
  document.getElementById('prog-label').textContent=pct+'% read';
  let cur='overview';
  for(const id of navIds){const el=document.getElementById(id);if(el&&el.getBoundingClientRect().top<=120)cur=id;}
  document.querySelectorAll('.nav-item').forEach(item=>{item.classList.toggle('active',item.getAttribute('href')==='#'+cur);});
}
window.addEventListener('scroll',updateNav);
document.querySelectorAll('.nav-item').forEach(item=>{
  item.addEventListener('click',function(){
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    this.classList.add('active');
    const sb=document.querySelector('.sidebar'),it=this.offsetTop;
    if(it>sb.scrollTop+sb.clientHeight-80||it<sb.scrollTop+60)sb.scrollTop=it-sb.clientHeight/2;
  });
});
