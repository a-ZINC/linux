    <tr><td><code>universe</code></td><td>Community-maintained open-source</td><td>Community only</td></tr>
    <tr><td><code>multiverse</code></td><td>Non-free, patent-encumbered</td><td>No support</td></tr>
    <tr><td><code>security</code></td><td>Security updates only</td><td>Critical</td></tr>
    <tr><td><code>updates</code></td><td>Stable bug fixes post-release</td><td>Stable</td></tr>
    <tr><td><code>backports</code></td><td>Newer versions backported to older releases</td><td>Use carefully</td></tr>
  </table>

