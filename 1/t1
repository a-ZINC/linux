<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0e0f11;
    --surface: #15171a;
    --surface2: #1c1f23;
    --surface3: #23272d;
    --border: #2a2e35;
    --border2: #363c45;
    --text: #e8eaed;
    --text2: #9aa0ab;
    --text3: #5f666f;
    --accent: #4fffb0;
    --accent2: #00d4ff;
    --accent3: #ff6b6b;
    --accent4: #ffd93d;
    --accent5: #c084fc;
    --accent6: #fb923c;
    --green: #22c55e;
    --red: #ef4444;
    --yellow: #f59e0b;
    --blue: #3b82f6;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Syne', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    font-size: 15px;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* Layout */
  .app { display: flex; min-height: 100vh; }

  /* Sidebar */
  .sidebar {
    width: 260px;
    flex-shrink: 0;
    background: var(--surface);
    border-right: 1px solid var(--border);
    position: fixed;
    top: 0; left: 0; bottom: 0;
    overflow-y: auto;
    z-index: 100;
    display: flex;
    flex-direction: column;
  }

  .sidebar-header {
    padding: 20px 16px 16px;
    border-bottom: 1px solid var(--border);
  }

  .phase-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    background: rgba(79,255,176,0.12);
    color: var(--accent);
    border-radius: 4px;
    border: 1px solid rgba(79,255,176,0.25);
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }

  .sidebar-header h1 {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .sidebar-header p {
    font-size: 11px;
    color: var(--text3);
    margin-top: 4px;
    font-family: var(--mono);
  }

  .nav-section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text3);
    padding: 16px 16px 6px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    font-size: 12.5px;
    color: var(--text2);
    cursor: pointer;
    border-left: 2px solid transparent;
    transition: all 0.15s;
    text-decoration: none;
  }

  .nav-item:hover { color: var(--text); background: var(--surface2); }
  .nav-item.active { color: var(--accent); border-left-color: var(--accent); background: rgba(79,255,176,0.05); }

  .nav-icon { font-size: 13px; width: 16px; flex-shrink: 0; }

  .progress-bar {
    margin: 16px;
    background: var(--surface3);
    border-radius: 4px;
    height: 4px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 4px;
    width: 0%;
    transition: width 0.3s;
  }
  .progress-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text3);
    margin: 0 16px 16px;
  }

  /* Main Content */
  .main {
    margin-left: 260px;
    flex: 1;
    max-width: 900px;
    padding: 40px 48px;
  }

  /* Hero */
  .hero {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .topic-tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    display: block;
  }

  .hero h1 {
    font-size: 42px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero h1 span { color: var(--accent); }

  .hero-meta {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .meta-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text2);
  }

  .meta-chip .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .hero-desc {
    font-size: 16px;
    color: var(--text2);
    line-height: 1.7;
    max-width: 680px;
  }

  .outcomes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
    margin-top: 20px;
  }

  .outcome-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    color: var(--text2);
    padding: 10px 14px;
    background: var(--surface2);
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .outcome-item::before {
    content: '✓';
    color: var(--accent);
    font-weight: 700;
    flex-shrink: 0;
    font-size: 12px;
    margin-top: 1px;
  }

  /* Sections */
  .section {
    margin-bottom: 56px;
    scroll-margin-top: 24px;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .section-icon {
    font-size: 18px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface2);
    border-radius: 8px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .section-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
  }

  .section-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text3);
    margin-top: 2px;
  }

  h3 {
    font-size: 15px;
    font-weight: 700;
    color: var(--accent2);
    margin: 20px 0 8px;
    font-family: var(--mono);
  }

  p { color: var(--text2); line-height: 1.75; margin-bottom: 12px; }
  p strong { color: var(--text); font-weight: 600; }

  /* Note Blocks */
  .note {
    border-radius: 8px;
    padding: 16px 18px;
    margin: 16px 0;
    border-left: 3px solid;
  }

  .note-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-family: var(--mono);
  }

  .note p { margin: 0; font-size: 14px; }

  .note-mental { background: rgba(79,255,176,0.06); border-color: var(--accent); }
  .note-mental .note-label { color: var(--accent); }

  .note-cmd { background: rgba(0,212,255,0.06); border-color: var(--accent2); }
  .note-cmd .note-label { color: var(--accent2); }

  .note-files { background: rgba(251,146,60,0.06); border-color: var(--accent6); }
  .note-files .note-label { color: var(--accent6); }

  .note-hood { background: rgba(192,132,252,0.06); border-color: var(--accent5); }
  .note-hood .note-label { color: var(--accent5); }

  .note-real { background: rgba(34,197,94,0.06); border-color: var(--green); }
  .note-real .note-label { color: var(--green); }

  .note-warn { background: rgba(239,68,68,0.06); border-color: var(--red); }
  .note-warn .note-label { color: var(--red); }

  .note-debug { background: rgba(245,158,11,0.06); border-color: var(--yellow); }
  .note-debug .note-label { color: var(--yellow); }

  .note-sec { background: rgba(239,68,68,0.08); border-color: #ff4444; }
  .note-sec .note-label { color: #ff4444; }

  .note-perf { background: rgba(0,212,255,0.06); border-color: #00b4d8; }
  .note-perf .note-label { color: #00b4d8; }

  .note-senior { background: rgba(192,132,252,0.08); border-color: var(--accent5); }
  .note-senior .note-label { color: var(--accent5); }

  .note-try { background: rgba(79,255,176,0.06); border-color: var(--accent); }
  .note-try .note-label { color: var(--accent); }

  .note-break { background: rgba(255,107,107,0.06); border-color: var(--accent3); }
  .note-break .note-label { color: var(--accent3); }

  /* Code blocks */
  pre {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    overflow-x: auto;
    margin: 12px 0;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
  }

  code {
    font-family: var(--mono);
    font-size: 13px;
    background: var(--surface3);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent2);
  }

  pre code {
    background: none;
    padding: 0;
    color: var(--text);
  }

  .comment { color: var(--text3); }
  .cmd-name { color: var(--accent); }
  .flag { color: var(--accent4); }
  .string { color: var(--green); }
  .output { color: var(--text2); }

  /* Tables */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 13.5px;
  }

  th {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--text3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 8px 12px;
    background: var(--surface2);
    border: 1px solid var(--border);
    text-align: left;
  }

  td {
    padding: 9px 12px;
    border: 1px solid var(--border);
    color: var(--text2);
    vertical-align: top;
  }

  td code { font-size: 12px; }
  tr:hover td { background: var(--surface2); }

  /* Lists */
  ul, ol {
    padding-left: 20px;
    margin: 10px 0;
  }

  li {
    color: var(--text2);
    margin-bottom: 6px;
    line-height: 1.6;
    font-size: 14px;
  }

  li strong { color: var(--text); }

  /* Divider */
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }

  /* Quiz */
  .quiz-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    margin: 12px 0;
  }

  .quiz-q {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 12px;
  }

  .quiz-options { display: flex; flex-direction: column; gap: 6px; }

  .quiz-opt {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--surface3);
    border-radius: 6px;
    font-size: 13px;
    color: var(--text2);
    cursor: pointer;
    border: 1px solid var(--border);
    transition: all 0.15s;
    user-select: none;
  }

  .quiz-opt:hover { border-color: var(--border2); color: var(--text); }
  .quiz-opt.correct { background: rgba(34,197,94,0.1); border-color: var(--green); color: var(--green); }
  .quiz-opt.wrong { background: rgba(239,68,68,0.1); border-color: var(--red); color: var(--red); }

  .quiz-opt-key {
    font-family: var(--mono);
    font-size: 11px;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface2);
    border-radius: 4px;
    flex-shrink: 0;
    color: var(--text3);
  }

  /* Cheat sheet */
  .cheat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 12px;
  }

  .cheat-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }

  .cheat-card h4 {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .cheat-row {
    display: flex;
    gap: 8px;
    align-items: baseline;
    margin-bottom: 5px;
    font-size: 13px;
  }

  .cheat-cmd {
    font-family: var(--mono);
    color: var(--accent2);
    flex-shrink: 0;
    min-width: 130px;
    font-size: 12px;
  }

  .cheat-desc { color: var(--text3); font-size: 12px; }

  /* Interview questions */
  .iq-item {
    border-left: 2px solid var(--border2);
    padding: 10px 16px;
    margin: 8px 0;
    transition: border-color 0.15s;
  }

  .iq-item:hover { border-left-color: var(--accent); }

  .iq-level {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .level-jr { color: var(--green); }
  .level-mid { color: var(--yellow); }
  .level-sr { color: var(--accent3); }

  .iq-q { font-size: 14px; color: var(--text); font-weight: 500; }

  .iq-hint {
    font-size: 12px;
    color: var(--text3);
    margin-top: 4px;
    font-style: italic;
  }

  /* Lab blocks */
  .lab-block {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin: 16px 0;
  }

  .lab-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--surface3);
    border-bottom: 1px solid var(--border);
  }

  .lab-badge {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .lab-badge.beginner { background: rgba(34,197,94,0.15); color: var(--green); }
  .lab-badge.intermediate { background: rgba(245,158,11,0.15); color: var(--yellow); }
  .lab-badge.advanced { background: rgba(239,68,68,0.15); color: var(--red); }

  .lab-title { font-size: 14px; font-weight: 600; color: var(--text); }

  .lab-body { padding: 14px 16px; }

  .lab-step {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-bottom: 10px;
    font-size: 13.5px;
    color: var(--text2);
  }

  .step-num {
    font-family: var(--mono);
    font-size: 11px;
    background: var(--surface3);
    border: 1px solid var(--border);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    flex-shrink: 0;
    color: var(--accent);
    margin-top: 1px;
  }

  /* Incident block */
  .incident {
    background: rgba(239,68,68,0.04);
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 10px;
    padding: 20px;
    margin: 16px 0;
  }

  .incident-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    color: var(--red);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .incident h4 {
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }

  /* Recap box */
  .recap {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    margin: 16px 0;
  }

  .recap h4 {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  /* Senior block */
  .senior-block {
    background: linear-gradient(135deg, rgba(192,132,252,0.06) 0%, rgba(79,255,176,0.04) 100%);
    border: 1px solid rgba(192,132,252,0.25);
    border-radius: 10px;
    padding: 20px 24px;
    margin: 20px 0;
  }

  .senior-block h4 {
    font-size: 15px;
    font-weight: 700;
    color: var(--accent5);
    margin-bottom: 10px;
  }

  /* TOC scroll spy */
  .toc-count {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text3);
    margin-left: auto;
  }

  /* Mobile toggle */
  .mob-toggle {
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    font-size: 18px;
    cursor: pointer;
    font-family: var(--mono);
    font-weight: 700;
  }

  @media (max-width: 800px) {
    .sidebar { transform: translateX(-100%); transition: transform 0.2s; }
    .sidebar.open { transform: translateX(0); }
    .main { margin-left: 0; padding: 24px 20px; }
    .mob-toggle { display: flex; align-items: center; justify-content: center; }
    .hero h1 { font-size: 28px; }
  }
</style>
</head>
