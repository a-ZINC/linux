<span class="cmd-name">wc</span> <span class="flag">-l</span> <span class="string">file.txt</span>        <span class="comment"># count lines in file</span>
<span class="cmd-name">grep</span> <span class="string">"error" file.txt</span> <span class="comment"># search for "error" in file</span>
<span class="cmd-name">grep</span> <span class="flag">-r</span> <span class="string">"error" /var/log</span> <span class="comment"># recursive search in directory</span>
<span class="cmd-name">find</span> <span class="string">/home</span> <span class="flag">-name</span> <span class="string">"*.txt"</span>  <span class="comment"># find files by name pattern</span>
<span class="cmd-name">clear</span>                  <span class="comment"># clear the terminal screen</span>
<span class="cmd-name">exit</span>                   <span class="comment"># exit the shell / close SSH session</span></code></pre>
    </div>

    <!-- S4: Files & Configs -->
    <div class="section" id="s4">
      <div class="section-header">
        <div class="section-icon">📁</div>
        <div>
          <div class="section-title">Important Files & Configs</div>
          <div class="section-num">Section 04 — Where the shell lives and stores settings</div>
        </div>
